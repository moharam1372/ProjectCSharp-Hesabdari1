<Window x:Class="MyCom.Waiting.PleaseWait"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
         Height="164" Width="352" WindowStartupLocation="CenterScreen" ShowInTaskbar="False" ResizeMode="NoResize">
    <Grid >

        <ProgressBar Name="_barWait" Margin="0,0,0,15" HorizontalAlignment="Center" Height="25"  VerticalAlignment="Bottom" Width="325" Value="50" ValueChanged="_barWait_ValueChanged">
            <ProgressBar.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <LinearGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                            <SkewTransform CenterX="0.5" CenterY="0.5"/>
                            <RotateTransform Angle="29.249" CenterX="0.5" CenterY="0.5"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </LinearGradientBrush.RelativeTransform>
                    <GradientStop Color="#FF3A75C3"/>
                    <GradientStop Color="#FF44D8FF" Offset="0.991"/>
                </LinearGradientBrush>
            </ProgressBar.Foreground>

        </ProgressBar>
        <Label Name="_lblShowPercent" Content="50%" HorizontalAlignment="Center" Margin="0,0,0,7" VerticalAlignment="Bottom" Height="36" FontSize="15"/>
        <Image Name="_imgPlease" HorizontalAlignment="Right" Height="45" Margin="0,10,10,0" VerticalAlignment="Top" Width="45" Source="/KavoshPack;component/Resources/loading.gif" Visibility="Visible"/>
        <Label Name="_lblTitleWait" FlowDirection="RightToLeft" Margin="0 50 0 0" Content="در حال به روز رسانی ..." HorizontalAlignment="Center" VerticalAlignment="Top" Height="40" Width="249" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <Label Name="_lblTitleGame" FlowDirection="RightToLeft" Margin="0 15 0 0" Content="Warzone" HorizontalAlignment="Center" VerticalAlignment="Top" Height="40" Width="249" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>



    </Grid>
</Window>
